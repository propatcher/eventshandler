# === Docker Compose переменные ===
# Скопируйте в файл `.env` рядом с docker-compose.yml и заполните для сервера.

# ОБЯЗАТЕЛЬНО смените на длинную случайную строку (подпись JWT):
SECRET_KEY=change-me-to-a-long-random-secret

# База данных PostgreSQL:
POSTGRES_USER=events
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=events

# Порты, публикуемые на хосте сервера.
# Фронтенд (Caddy) всегда слушает 80 и 443 — отдельная переменная не нужна.
BACKEND_PORT=8000
DB_PORT=5432        # на проде лучше не открывать БД наружу (закройте файрволом)

# Домен фронтенда для CORS (через запятую), напр. https://eventlys.ru:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email-адреса администраторов через запятую (опционально):
ADMIN_EMAILS=
