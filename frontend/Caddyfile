# Caddy сам получает и автоматически продлевает сертификат Let's Encrypt
# для доменного блока ниже. Локально (localhost) работает по HTTP без сертификата.
# (необязательно) чтобы получать письма об истечении сертификата —
# раскомментируйте блок и впишите свою почту:
# {
# 	email you@example.com
# }

(app) {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	# API → бэкенд (uvicorn слушает порт 8000 внутри docker-сети)
	handle /api/* {
		reverse_proxy backend:8000
	}

	# SPA: статика, любой неизвестный путь отдаём index.html
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

eventlys.ru, www.eventlys.ru {
	import app
}

http://localhost, http://127.0.0.1 {
	import app
}
